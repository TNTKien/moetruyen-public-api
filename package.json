{
  "name": "moetruyen-public-api",
  "version": "0.1.0",
  "private": true,
  "description": "Public read-only REST API for Moe Truyen",
  "type": "module",
  "packageManager": "bun@1.2.9",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "db:pull": "drizzle-kit pull"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/standard-validator": "^0.1.2",
    "@scalar/hono-api-reference": "^0.5.159",
    "drizzle-orm": "^0.44.0",
    "hono": "^4.7.10",
    "hono-openapi": "^0.4.8",
    "pg": "^8.16.3",
    "zod": "^4.1.5",
    "zod-openapi": "^4.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.15.6",
    "dotenv": "^17.2.2",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.36.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1"
  }
}
