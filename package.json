{
  "name": "moetruyen-public-api",
  "version": "0.2.0",
  "private": true,
  "description": "Public read-only REST API for Moe Truyen",
  "type": "module",
  "packageManager": "bun@1.2.9",
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "eslint .",
    "db:pull": "drizzle-kit pull"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@hono/standard-validator": "^0.2.2",
    "@scalar/hono-api-reference": "^0.10.4",
    "apitally": "^0.25.4",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.8",
    "hono-openapi": "^1.3.0",
    "hono-rate-limiter": "^0.5.3",
    "pg": "^8.20.0",
    "zod": "^4.3.6",
    "zod-openapi": "^5.4.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
